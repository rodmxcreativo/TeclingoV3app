{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Professional profile for teachers and users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "curp": { "type": "string" },
        "employeeId": { "type": "string" },
        "controlNumber": { "type": "string" },
        "phone": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "string" },
        "institutionId": { "type": "string" },
        "courseLicenseCode": { "type": "string" },
        "career": { "type": "string" },
        "module": { "type": "number" },
        "semester": { "type": "string" },
        "group": { "type": "string" },
        "role": { "type": "string", "enum": ["DIRECTOR", "DOCENTE", "ALUMNO", "SUPERADMIN"] },
        "hasAcceptedTerms": { "type": "boolean" },
        "termsAcceptedAt": { "type": "string", "format": "date-time" },
        "termsAcceptedIp": { "type": "string" },
        "isSuperAdmin": { "type": "boolean" },
        "registredAt": { "type": "string", "format": "date-time" },
        "certifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "url": { "type": "string" },
              "date": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Entity representing a school or organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "directorId": { "type": "string" },
        "registrationCode": { "type": "string" },
        "codeExpirationDate": { "type": "string", "format": "date-time" },
        "isRegistrationActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "licenseStatus": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "PENDING"] }
      },
      "required": ["id", "name", "directorId"]
    },
    "ActivationCode": {
      "title": "Activation Code",
      "description": "License codes generated by SuperAdmin.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "status": { "type": "string", "enum": ["AVAILABLE", "USED", "EXPIRED"] },
        "usedBy": { "type": "string", "description": "Institution ID that used the code" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "status"]
    },
    "TutorRulesEntry": {
      "title": "Tutor Rules Entry",
      "description": "Rule or knowledge entry added by the Director to customize AI Tutor responses.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "content": { "type": "string" },
        "example": { "type": "string" },
        "updatedAt": { "type": "string" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "topic", "content"]
    },
    "LibraryDocument": {
      "title": "Library Document",
      "description": "Syllabus JSON or technical manual PDF uploaded by Director.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "string" },
        "type": { "type": "string", "enum": ["json", "pdf"] },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "checksum": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "size", "type"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Audit trails and user actions recorded automatically.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "data": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["type", "timestamp", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profile and professional data."
    },
    "/institutions/{instId}": {
      "schema": "Institution",
      "description": "Stores institutional settings and registry control."
    },
    "/activationCodes/{codeId}": {
      "schema": "ActivationCode",
      "description": "Global license codes for the SuperAdmin."
    },
    "/tutor_knowledge/{knowledgeId}": {
      "schema": "TutorRulesEntry",
      "description": "Collection of pedagogical facts and responses fed by the director to make the AI Tutor 100% coherent."
    },
    "/library_documents/{docId}": {
      "schema": "LibraryDocument",
      "description": "Shared directory of academic guides, official schedules, and structural mallas."
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Diagnostic and security audit logging."
    }
  }
}
