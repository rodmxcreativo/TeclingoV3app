      {/* Main Library Tab Selector */}
      <div className="flex flex-col md:flex-row bg-black/45 border border-white/5 p-1 rounded-2xl max-w-5xl gap-1.5 self-start shadow-[0_4px_20px_rgba(0,0,0,0.5)] flex-wrap">
