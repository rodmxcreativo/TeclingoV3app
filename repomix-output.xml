                            className="bg-white/5 hover:bg-white/10 text-white/50 hover:text-white text-[8px] font-bold uppercase px-2 py-1 rounded-lg transition-colors"
                          >
                            No
                          </button>
                        </div>
                      ) : (
                        <button 
