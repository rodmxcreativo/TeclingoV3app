          return c;
        }
        return {
          ...c,
          subjects: [...c.subjects, newSub]
        };
      }
      return c;
    }));
    
    setNewSubjectName('');
    setNewSubjectCode('');
    setNewSubjectSemester(1);
    setNewSubjectHours(4);
    setShowAddSubjectModal(null);
  };

