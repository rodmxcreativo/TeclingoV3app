<file path="src/index.css">
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
  
  --color-neon: #DEFF9A;
  --color-cyan: #4ADE80;
  --color-alert: #F59E0B;
  --color-teal-dark: #061a1a;
}

@layer base {
  :root {
    --neon: #DEFF9A;
    --cyan: #4ADE80;
    --alert: #F59E0B;
    --teal-dark: #061a1a;
    --glass: rgba(255, 255, 255, 0.04);
    --glass-border: rgba(222, 255, 154, 0.15);
    --bg-main: #061a1a;
    --text-main: #f8fafc;
  }

  :root.light {
    --teal-dark: #f0fdf4;
    --glass: rgba(6, 26, 26, 0.05);
    --glass-border: rgba(6, 26, 26, 0.1);
    --bg-main: #f8fafc;
    --text-main: #061a1a;
  }

  body {
    background-color: var(--bg-main);
    color: var(--text-main);
    overflow-x: hidden;
    transition: background-color 0.3s ease, color 0.3s ease;
    -webkit-tap-highlight-color: transparent;
    max-width: 100vw;
  }

  /* Ensure app fits in 9:16 vertical viewport */
  #root {
    max-width: 100vw;
    overflow-x: hidden;
    position: relative;
  }
}

@layer utilities {
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--glass-border);
    border-radius: 10px;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .bg-mesh {
    background-image: 
      radial-gradient(circle at 20% 30%, rgba(74, 222, 128, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(222, 255, 154, 0.1) 0%, transparent 50%),
      linear-gradient(rgba(13, 45, 45, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13, 45, 45, 0.1) 1px, transparent 1px);
    background-size: 100% 100%, 100% 100%, 40px 40px, 40px 40px;
  }

  :root.light .bg-mesh {
    background-image: 
      radial-gradient(circle at 20% 30%, rgba(74, 222, 128, 0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(222, 255, 154, 0.05) 0%, transparent 50%),
      linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
  }

  .neo-glass {
    background: var(--glass);
    backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4), inset 0 0 15px rgba(222, 255, 154, 0.05);
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.2s ease;
  }

  /* 3D Haptic Control System */
  .haptic-press {
    transition: transform 0.15s cubic-bezier(0.2, 0, 0.2, 1), box-shadow 0.15s ease, filter 0.15s ease;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .haptic-press:active {
    transform: perspective(1000px) translate3d(0, 2px, -4px) scale(0.98);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.4), inset 0 2px 4px rgba(0, 0, 0, 0.5);
    filter: brightness(0.9);
  }

  .haptic-press:hover {
    transform: perspective(1000px) translate3d(0, -2px, 2px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 15px var(--glass-border);
  }

  /* Neon Haptic Button */
  .haptic-button {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(222, 255, 154, 0.1);
    color: white;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: transform 0.15s cubic-bezier(0.2, 0, 0.2, 1), box-shadow 0.15s ease, filter 0.15s ease;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .haptic-button:active {
    transform: perspective(1000px) translate3d(0, 2px, -4px) scale(0.98);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.4), inset 0 2px 4px rgba(0, 0, 0, 0.5);
    filter: brightness(0.9);
  }

  .haptic-button:hover {
    transform: perspective(1000px) translate3d(0, -2px, 2px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 15px var(--glass-border);
  }

  .haptic-button-primary {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    background: rgba(222, 255, 154, 0.1);
    border: 1px solid rgba(222, 255, 154, 0.3);
    color: #DEFF9A;
    box-shadow: 0 8px 32px rgba(222, 255, 154, 0.1);
    transition: transform 0.15s cubic-bezier(0.2, 0, 0.2, 1), box-shadow 0.15s ease, filter 0.15s ease;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .haptic-button-primary:hover {
    background: rgba(222, 255, 154, 0.2);
    border: 1px solid rgba(222, 255, 154, 0.5);
    box-shadow: 0 12px 40px rgba(222, 255, 154, 0.2), 0 0 20px rgba(222, 255, 154, 0.3);
    transform: perspective(1000px) translate3d(0, -2px, 2px);
  }

  .haptic-button-primary:active {
    transform: perspective(1000px) translate3d(0, 2px, -4px) scale(0.98);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.4), inset 0 2px 4px rgba(0, 0, 0, 0.5);
    filter: brightness(0.9);
  }

  /* Mechanical Input focus */
  .haptic-input {
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(0, 0, 0, 0.2);
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .haptic-input:focus {
    outline: none;
    border-color: rgba(222, 255, 154, 0.4);
    background: rgba(222, 255, 154, 0.03);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4), inset 0 1px 2px rgba(222, 255, 154, 0.1);
    transform: translateY(-2px);
  }

  /* 3D Switch */
  .haptic-switch {
    @apply relative cursor-pointer transition-all duration-300;
    transform-style: preserve-3d;
  }

  .haptic-switch:active {
    transform: rotateX(15deg);
  }

  .bevel-text {
    text-shadow: 0 0 10px rgba(222, 255, 154, 0.4);
  }

  .neon-border-glow {
    box-shadow: 0 0 8px var(--neon);
  }
}
