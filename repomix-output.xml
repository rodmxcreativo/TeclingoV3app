    'ISC-201': ['chucho_serna', 'luis_garcia'],
    'ISC-202': ['roberto_her', 'chucho_serna'],
    'ISC-203': ['sofia_ruiz', 'roberto_her', 'ana_lopez'],
    'ISC-204': ['luis_garcia', 'chucho_serna'],
    'ISC-205': ['roberto_her', 'sofia_ruiz'],
  };

